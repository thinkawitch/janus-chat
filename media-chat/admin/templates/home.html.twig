{% extends 'base.html.twig' %}

{% block title %}Overview{% endblock %}

{% block body %}
<h1>Overview</h1>
<div {{ stimulus_controller('home') }}>
    <input type="text" {{ stimulus_target('home', 'name') }}>

    <button {{ stimulus_action('home', 'greet') }}>
        Greet
    </button>

    <div {{ stimulus_target('home', 'output') }}></div>


    <button {{ stimulus_action('home', 'getRooms') }}>
        Get rooms
    </button>

</div>
{% endblock %}
